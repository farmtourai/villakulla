rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 우리 가족 허용 목록 ──
    // 로그인한 사용자의 이메일이 아래 목록에 있을 때만 접근 허용.
    // 가족 계정 이메일을 모두 소문자로 추가하세요.
    function isFamily() {
      return request.auth != null && request.auth.token.email in [
        'farmtourai@gmail.com',   // 관리자(부모)
        'moakboy@naver.com',      // 큰아들
        'moakangel@naver.com',    // 딸
        'moakman@naver.com',      // 둘째아들
        'moakking@naver.com'      // 막내아들
      ];
    }

    // 가족 공유 데이터(일기·캘린더·칭찬 등)
    match /shared/{docId} {
      allow read, write: if isFamily();
    }

    // 그 외 모든 경로는 차단 (기본 거부)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
